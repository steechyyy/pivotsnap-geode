{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "steechy.pivot_snap",
	"name": "Pivot Snap",
	"version": "v1.1.4",
	"developer": "steechy",
	"description": "allows easy snapping when warping objects",

	"settings": {

		"title": {
			"type": "title",
			"name": "Pivot Snap Settings"
		},

		"snap-method": {
			"name": "Snap method",
			"description": "change the snapping behavior of the pivot point to your liking!!",
			"type": "string",
			"default": { "win": "keybind", "mac": "keybind", "android": "button" },
			"one-of": [ "keybind", "button" ]
		},

		"snap-keybind":	{
			"type": "keybind",
			"name": "Snap Keybind",
			"description": "snap the pivot point",
			"default": "[X]",
			"category": "editor",
			"migrate-from": "steechy.pivot_snap/pivot_snap"
		}

	},

	"dependencies": {
		"geode.node-ids": "1.19.0"
	},

	"resources": {
		"sprites": [
			"resources/GJ_snapBtn_001.png"
		]
	},

	"links": {
		"source": "https://github.com/steechyyy/pivotsnap-geode"
	},

	"tags": [ "editor", "utility", "enhancement" ]

}
